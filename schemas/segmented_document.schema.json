{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "segmented_document.schema.json",
  "title": "Segmented Document",
  "type": "object",
  "required": ["document_id", "actor_id", "segments"],
  "properties": {
    "document_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment_id", "paragraph_index", "sentence_index", "text"],
        "properties": {
          "segment_id": { "type": "string" },
          "paragraph_index": { "type": "integer" },
          "sentence_index": { "type": "integer" },
          "text": { "type": "string" }
        }
      }
    }
  }
}

